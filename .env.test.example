# Preview deployment URL (get from: vercel ls)
PREVIEW_URL=https://smart-invoice-workflow-abc123.vercel.app

# Or use production
TEST_ENV=production

# Vercel Deployment Protection Bypass (REQUIRED for Preview testing)
# Get this from: Vercel Dashboard → Project Settings → Deployment Protection → "Protection Bypass for Automation"
# NOTE: This is stored in Doppler - run `doppler secrets download --no-file --format env > .env` to sync
# Without this, Playwright tests will fail with "Authentication Required" on Preview deployments
VERCEL_AUTOMATION_BYPASS_SECRET=your_bypass_secret_here

